# Bapita Dashboard — environment variables
#
# Copy to .env.local for local dev and fill in the values.
# On Vercel, set ALL of these for every environment that should run the app:
# Production, Preview, and Development (Settings > Environment Variables).
# Missing them causes the build to fail while prerendering pages such as
# /addons: "@supabase/ssr: Your project's URL and API key are required".
#
# Values come from the Supabase dashboard:
#   Project > Settings > API
#   https://supabase.com/dashboard/project/_/settings/api

# Public — safe to expose to the browser (used by client and server)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret — server only. NEVER expose to the browser or commit a real value.
# Used by the service client and API routes (e.g. booking, send-confirmation).
SUPABASE_SERVICE_ROLE_KEY=
